# ElevenLabs Credentials
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Cloned Voice ID (find it in ElevenLabs dashboard > Voices > click your voice)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model to use (recommended: eleven_flash_v2_5 for speed + long context)
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Max characters per chunk (keep under 40,000 for Flash v2.5). 35000 is safe.
MAX_CHUNK_CHARS=35000

# Voice settings (optional, 0.0 - 1.0). Higher = more stable but less expressive.
STABILITY=0.75
SIMILARITY_BOOST=0.85
STYLE=0.0
USE_SPEAKER_BOOST=true
